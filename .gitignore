# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual environment ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Data — raw inputs ──────────────────────
BANKNIFTY/*
!BANKNIFTY/.gitkeep


# ─── Data — intermediate pipeline outputs ──────
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/features/*
!data/features/.gitkeep

data/option_chain_processed/*
!data/option_chain_processed/.gitkeep

data/daily_features/*
!data/daily_features/.gitkeep


# ─── Model artifacts ──────────────────
models/*
!models/.gitkeep


# ─── Pipeline outputs ──
outputs/*
!outputs/.gitkeep


# ─── Plot outputs ─────────────────────
Analysis_outcomes/*
!Analysis_outcomes/.gitkeep

Visualizations/*
!Visualizations/.gitkeep

outcomes/*
!outcomes/.gitkeep


# ─── Daily raw inputs ───────────────
data/option_chain_raw/*
!data/option_chain_raw/.gitkeep

# ─── Claude local config ──────────────────────────────────────────────────────
.claude/

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# Ignore all .md files
*.md

# Exceptions (Do NOT ignore these)
!README.md
!QUICKSTART.md
!DOCUMENTATION.md

# Ignore all Word documents
*.docx
*.doc

