# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual environment ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Data — raw inputs (large Excel files, not tracked) ──────────────────────
BANKNIFTY/*
!BANKNIFTY/.gitkeep


# ─── Data — intermediate pipeline outputs (regenerated by preprocess.py) ──────
data/raw/
data/processed/
data/features/
data/option_chain_processed/
data/daily_features/

# ─── Model artifacts (regenerated by train.py / retrain.py) ──────────────────
models/

# ─── Pipeline outputs (regenerated by train.py / retrain.py / daily_run.py) ──
outputs/

# ─── Plot outputs (regenerated by each script) ────────────────────────────────
Analysis_outcomes/
Visualizations/
outcomes/

# ─── Daily raw inputs (user-dropped CSVs, not tracked) ───────────────────────
data/option_chain_raw/

# ─── Claude local config ──────────────────────────────────────────────────────
.claude/

# ─── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# Ignore all .md files
*.md

# Exceptions (Do NOT ignore these)
!README.md
!QUICKSTART.md
!DOCUMENTATION.md

# Ignore all Word documents
*.docx
*.doc

